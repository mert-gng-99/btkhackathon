generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Auth.js / NextAuth v5
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  authSessions    Session[]
  apiConnections  ApiConnection[]
  tradingSessions TradingSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// Binance integration
// ============================================================================

model ApiConnection {
  id                 String    @id @default(cuid())
  userId             String?
  exchange           String    @default("binance")
  apiKeyEncrypted    String?
  apiSecretEncrypted String?
  isReadOnly         Boolean
  createdAt          DateTime  @default(now())
  lastSyncedAt       DateTime?

  user User? @relation(fields: [userId], references: [id])
}

model TradingSession {
  id        String   @id
  userId    String?
  source    String   @default("binance")
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User?               @relation(fields: [userId], references: [id])
  trades    Trade[]
  analytics AnalyticsSnapshot[]
  chunks    RagChunk[]
  reports   AiReport[]
}

model Trade {
  id            String   @id @default(cuid())
  sessionId     String
  exchange      String   @default("binance")
  marketType    String   @default("spot")
  symbol        String
  orderId       String
  tradeId       String
  side          String
  price         Decimal
  quantity      Decimal
  quoteQuantity Decimal
  fee           Decimal
  feeAsset      String
  timestamp     DateTime
  isBuyer       Boolean
  isMaker       Boolean
  realizedPnl   Decimal?
  positionSide  String?

  tradingSession TradingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([sessionId, symbol])
  @@unique([sessionId, exchange, marketType, symbol, tradeId])
}

model AnalyticsSnapshot {
  id           String   @id @default(cuid())
  sessionId    String
  metricsJson  Json
  insightsJson Json
  createdAt    DateTime @default(now())

  tradingSession TradingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model RagChunk {
  id           String   @id @default(cuid())
  sessionId    String
  sourceType   String
  sourceRef    String
  content      String
  metadataJson Json
  embedding    Json?
  createdAt    DateTime @default(now())

  tradingSession TradingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sourceType])
}

model AiReport {
  id          String   @id @default(cuid())
  sessionId   String
  type        String
  contentJson Json
  createdAt   DateTime @default(now())

  tradingSession TradingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, type])
}

// ============================================================================
// Anonymous trader registry
// ============================================================================

model AnonymousTraderProfile {
  id                 String   @id @default(cuid())
  anonymousId        String   @unique
  displayName        String
  traderType         String
  confidence         String
  successRate        Float?
  buyRatio           Float
  rapidTradeRatio    Float
  lateNightRatio     Float
  feeToVolumeRatio   Float
  topSymbolShare     Float
  tradeCount         Int
  activeDays         Int
  primaryMarket      String
  topSymbolsJson     Json
  behavioralTagsJson Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  following AnonymousTraderFollow[] @relation("FollowerProfile")
  followers AnonymousTraderFollow[] @relation("TargetProfile")

  @@index([traderType])
  @@index([successRate])
  @@index([updatedAt])
}

model AnonymousTraderFollow {
  id                  String   @id @default(cuid())
  followerAnonymousId String
  targetAnonymousId   String
  createdAt           DateTime @default(now())

  follower AnonymousTraderProfile @relation("FollowerProfile", fields: [followerAnonymousId], references: [anonymousId], onDelete: Cascade)
  target   AnonymousTraderProfile @relation("TargetProfile", fields: [targetAnonymousId], references: [anonymousId], onDelete: Cascade)

  @@unique([followerAnonymousId, targetAnonymousId])
  @@index([targetAnonymousId])
}
