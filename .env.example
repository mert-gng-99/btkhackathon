# ============================================================================
# Database (PostgreSQL)
# Local: docker run --name pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
# Prod : Neon -> https://neon.tech (use the pooled URL for runtime + direct URL for migrations)
# ============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trade_analytics?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/trade_analytics?schema=public"

# ============================================================================
# Auth.js / NextAuth v5
# Generate AUTH_SECRET with: openssl rand -base64 32
# AUTH_URL is required only when not on Vercel (Vercel sets it automatically)
# ============================================================================
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============================================================================
# Binance API configuration
# ============================================================================
BINANCE_BASE_URL="https://api.binance.com"
BINANCE_UM_FUTURES_BASE_URL="https://fapi.binance.com"
BINANCE_COIN_FUTURES_BASE_URL="https://dapi.binance.com"
BINANCE_DEFAULT_SYMBOLS="BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,MATICUSDT"
BINANCE_DEFAULT_QUOTE_ASSETS="USDT,USDC,FDUSD,BTC,ETH,BNB,TRY,EUR"
BINANCE_MAX_PAGES_PER_SYMBOL="5"
BINANCE_FUTURES_MAX_WINDOWS_PER_SYMBOL="30"
BINANCE_SYMBOL_SCAN_DELAY_MS="120"
BINANCE_SYNC_CONCURRENCY="6"
SYNC_LOOKBACK_DAYS="3650"

# ============================================================================
# Encryption (32-byte base64 key). Generate with: openssl rand -base64 32
# ============================================================================
APP_ENCRYPTION_KEY=""

# ============================================================================
# Anonymous peer-discovery registry
# Set to "database" for production after `prisma db push`
# ============================================================================
TRADER_REGISTRY_STORAGE="database"
ANONYMIZATION_SALT="replace-with-a-long-random-production-secret"

# ============================================================================
# Gemini AI agents
# Get key at: https://aistudio.google.com/apikey
# ============================================================================
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# ============================================================================
# Upstash Redis (rate limit) -- https://upstash.com
# ============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================================
# Sentry monitoring -- https://sentry.io
# ============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
