# ============================================================================
# Database (PostgreSQL)
# Local : docker run --name pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
# Prod  : Neon -> https://neon.tech
#   - DATABASE_URL : pooled connection (host contains "-pooler"); used at runtime
#   - DIRECT_URL   : direct connection (no "-pooler"); used by prisma db push / migrate
# ============================================================================
DATABASE_URL=""
DIRECT_URL=""

# ============================================================================
# Auth.js / NextAuth v5
# Generate AUTH_SECRET with : openssl rand -base64 32
# AUTH_URL is required only when not on Vercel (Vercel sets it automatically).
# Create the Google OAuth client at https://console.cloud.google.com/apis/credentials
#   Authorized redirect URIs:
#     - http://localhost:3000/api/auth/callback/google
#     - https://<your-prod-domain>/api/auth/callback/google
# ============================================================================
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ============================================================================
# Binance API configuration
# Defaults are public Binance endpoints + a starter symbol/quote universe.
# ============================================================================
BINANCE_BASE_URL="https://api.binance.com"
BINANCE_UM_FUTURES_BASE_URL="https://fapi.binance.com"
BINANCE_COIN_FUTURES_BASE_URL="https://dapi.binance.com"
BINANCE_DEFAULT_SYMBOLS="BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,MATICUSDT"
BINANCE_DEFAULT_QUOTE_ASSETS="USDT,USDC,FDUSD,BTC,ETH,BNB,TRY,EUR"
BINANCE_MAX_PAGES_PER_SYMBOL="5"
BINANCE_FUTURES_MAX_WINDOWS_PER_SYMBOL="30"
BINANCE_SYMBOL_SCAN_DELAY_MS="120"
BINANCE_SYNC_CONCURRENCY="6"
SYNC_LOOKBACK_DAYS="3650"

# ============================================================================
# Encryption (32-byte base64). Used to encrypt persisted API keys.
# Generate with : openssl rand -base64 32
# ============================================================================
APP_ENCRYPTION_KEY=""

# ============================================================================
# Anonymous trader registry
# TRADER_REGISTRY_STORAGE : "database" (recommended, after `prisma db push`)
#                           or "memory" for stateless local demos.
# ANONYMIZATION_SALT      : long random string; generate with `openssl rand -hex 32`.
# ============================================================================
TRADER_REGISTRY_STORAGE="database"
ANONYMIZATION_SALT=""

# ============================================================================
# Gemini AI agents
# Get key at : https://aistudio.google.com/apikey  (free tier; no billing risk)
# ============================================================================
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_API_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# ============================================================================
# Upstash Redis  (rate limit backing store)
# Create database at : https://console.upstash.com
# When unset, rate limit falls back to an in-memory map (single process only).
# ============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================================
# Sentry monitoring
# Create a Next.js project at : https://sentry.io
# When SENTRY_DSN is unset, Sentry init is a no-op (silent in local dev).
# Auth token (https://sentry.io/settings/account/api/auth-tokens/) is only
# needed in CI / Vercel build for source map upload.
# ============================================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
